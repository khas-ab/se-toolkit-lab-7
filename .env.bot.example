# Bot configuration - copy to .env.bot.secret and fill in real values
# See wiki/dotenv-bot-secret.md for setup instructions

# Telegram bot token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# LMS API credentials
LMS_API_BASE_URL=http://localhost:42002
LMS_API_KEY=your_lms_api_key_here

# LLM API credentials (for Task 3)
LLM_API_MODEL=coder-model
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE_URL=http://localhost:42005/v1
